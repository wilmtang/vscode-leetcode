{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm",
            "type": "shell",
            "command": "npm",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "args": [
                "run",
                "compile",
                "--loglevel",
                "silent"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$tsc-watch"
        },
        {
            "type": "npm",
            "script": "lint",
            "problemMatcher": {
                "owner": "tslint",
                "fileLocation": "absolute",
                "applyTo": "allDocuments",
                "severity": "warning",
                "pattern": {
                    "regexp": "^(ERROR|WARNING):\\s+(.+?)\\[(\\d+),\\s*(\\d+)\\]:\\s+(.+)$",
                    "severity": 1,
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "message": 5
                }
            }
        }
    ]
}